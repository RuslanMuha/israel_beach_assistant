# Copy to .env (not committed) for local overrides. Render uses dashboard env vars.

# Server (Render sets PORT automatically)
PORT=8080

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/beach_assistant
SPRING_DATASOURCE_USERNAME=beach
SPRING_DATASOURCE_PASSWORD=beach

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# polling (default) or webhook
BEACH_TELEGRAM_MODE=polling

# Webhook (Render / HTTPS)
# TELEGRAM_PUBLIC_BASE_URL=https://your-service.onrender.com
# TELEGRAM_WEBHOOK_BASE_URL=
# BEACH_TELEGRAM_WEBHOOK_PATH=/api/telegram/webhook
# BEACH_TELEGRAM_WEBHOOK_AUTO_REGISTER=true
# TELEGRAM_WEBHOOK_SECRET=

# Optional: WebClient max response body buffer for provider HTTP (default 5242880). Raise if iNaturalist JSON is truncated.
# BEACH_HTTP_MAX_RESPONSE_BUFFER_BYTES=5242880
